# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# App
APP_NAME=AnomaGuard

# Real AWS credentials (IAM user: anomaguard-app)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# S3
S3_BUCKET_NAME=anomaguard-invoices

# DynamoDB (tables auto-created on first run)
DYNAMODB_TABLE_NAME=audit-invoices

# Login passwords
ADMIN_PASSWORD=choose_strong_password
REVIEWER_PASSWORD=choose_reviewer_password
VIEWER_PASSWORD=choose_viewer_password
